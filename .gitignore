# ========================
# Root .gitignore for Monorepo
# ========================

# -------------
# Dependencies
# -------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# -------------
# Build outputs (Frontend & Backend)
# -------------
dist/
dist-ssr/
build/
out/
target/
.next/
*.jar
*.war
*.ear

# -------------
# Environment files (Môi trường)
# -------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem

# -------------
# IDE & Editor files (Cấu hình máy cá nhân)
# -------------
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# -------------
# Testing, Logs & Coverage
# -------------
coverage/
.nyc_output/
*.log
.pytest_cache/
test-results/
playwright-report/
blob-report/
playwright/.cache/

# -------------
# Python/Java specific (nếu backend dùng)
# -------------
__pycache__/
*.py[cod]
*$py.class
.gradle/
.nb-gradle/

docs/
.CLAUDE.md